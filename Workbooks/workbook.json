{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 1,
      "content": {
        "json": "## Workspace Usage & Ingestion Telemetry Dashboard\n---\n*This master telemetry workspace blueprint monitors cross-tenant ingestion patterns, multi-source billing vectors, and active data lake retention matrices across all onboarded clients.*"
      },
      "name": "MSSP_Header_Title"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
            "id": "1f74ed9a-e3ed-4987-94d7-7504f2165f12",
            "version": "KqlParameterItem/1.0",
            "name": "TimeRange",
            "type": 4,
            "isRequired": true,
            "value": {
              "duration": {
                "value": 14,
                "unit": "d"
              }
            },
            "typeSettings": {
              "selectableValues": [
                {
                  "duration": {
                    "value": 1,
                    "unit": "d"
                  }
                },
                {
                  "duration": {
                    "value": 7,
                    "unit": "d"
                  }
                },
                {
                  "duration": {
                    "value": 14,
                    "unit": "d"
                  }
                },
                {
                  "duration": {
                    "value": 30,
                    "unit": "d"
                  }
                }
              ]
            }
          }
        ],
        "style": "pills",
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces"
      },
      "name": "Global_Time_Parameter"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Usage\n| where TimeGenerated {TimeRange}\n| summarize TotalBytes = sum(Quantity * 1024 * 1024) by DataType\n| sort by TotalBytes desc",
        "size": 0,
        "showAnalytics": true,
        "title": "Data Ingestion Distribution Breakdown by Component Log Source",
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "barchart",
        "chartSettings": {
          "xAxis": "DataType",
          "yAxis": [
            "TotalBytes"
          ],
          "seriesLabelSettings": [],
          "createLink": false
        }
      },
      "name": "Ingestion_Chart_Telemetry"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "Usage\n| where TimeGenerated {TimeRange}\n| summarize IngestedGB = sum(Quantity) / 1024 by bin(TimeGenerated, 1d), DataType\n| render timechart",
        "size": 0,
        "title": "Daily Data Lake Accumulation Ingestion Trends (GB)",
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "visualization": "timechart"
      },
      "name": "Daily_Trend_Analysis"
    }
  ],
  "isLocked": false
}
