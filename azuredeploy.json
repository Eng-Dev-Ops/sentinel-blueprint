{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": { "description": "The name of the Microsoft Sentinel Log Analytics Workspace." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "The regional location for deploying resources." }
    },
    "isOnboardingRequired": {
      "type": "bool",
      "defaultValue": true,
      "metadata": { "description": "Set to false if Microsoft Sentinel is already active on this workspace to avoid onboarding conflicts." }
    },
    "_artifactsLocation": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/Eng-Dev-Ops/sentinel-blueprint/testing/",
      "metadata": { "description": "The base URI path where the raw asset JSON blueprints are hosted on GitHub." }
    },
    "playbookFiles": {
      "type": "array",
      "defaultValue": [
        "abuseipdb_enrichment.json",
        "abuseipdb_report_teams.json",
        "as_azure_ad_disable_user.json",
        "as_slack_integration.json",
        "comment_remediation_steps.json",
        "enrich_malwarebazaar.json",
        "teams_notification.json"
      ],
      "metadata": { "description": "Dynamically updated manifest array of playbook JSON files managed by the GitHub Actions Robot." }
    },
    "analyticsRuleFiles": {
      "type": "array",
      "defaultValue": [
        "brute_force_detection.json",
        "c2_namedpipe.json",
        "disabled_accounts_signin.json",
        "domain_federation_modified.json",
        "mfa_spamming.json",
        "powershell_detection.json",
        "scheduled_task_hide.json",
        "sunburst_hashes.json",
        "unusual_file_deletion.json"
      ],
      "metadata": { "description": "Dynamically updated manifest array of analytics rule JSON files managed by the GitHub Actions Robot." }
    },
    "automationRuleFiles": {
      "type": "array",
      "defaultValue": [
        "autonomous_noise_mitigation.json",
        "emergency_p1_escalation.json",
        "incident_routing.json",
        "mssp_identity_containment.json",
        "ti_incident_enrichment.json",
        "tier1_triage_notification.json"
      ],
      "metadata": { "description": "Dynamically updated manifest array of automation rule JSON files managed by the GitHub Actions Robot." }
    },
    "maxSize": {
      "type": "int",
      "defaultValue": 10,
      "metadata": { "description": "Max loop control baseline threshold variable." }
    },
    "managedIdentityName": {
      "type": "string",
      "defaultValue": "Sentinel-Playbook-Execution-Identity",
      "metadata": { "description": "The name of the User-Assigned Managed Identity used to run the playbooks." }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[parameters('managedIdentityName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "azuresentinel",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "azuresentinel",
        "customParameterValues": {},
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "[format('Playbook-{0}', json(concat('\"', parameters('playbookFiles')[copyIndex()], '\"')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', 'azuresentinel')]"
      ],
      "copy": {
        "name": "playbookCopyLoop",
        "count": "[length(parameters('playbookFiles'))]",
        "mode": "Serial",
        "batchSize": 1
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), concat('Playbooks/', parameters('playbookFiles')[copyIndex()]))]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {}
      }
    },
    {
      "condition": "[parameters('isOnboardingRequired')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "SentinelOnboardingDeployment",
      "dependsOn": [
        "playbookCopyLoop"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), 'AnalyticsRules/sentinel_onboarding.json')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('workspaceName')]" }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "[format('AnalyticsRule-{0}', json(concat('\"', parameters('analyticsRuleFiles')[copyIndex()], '\"')))]",
      "dependsOn": [
        "playbookCopyLoop"
      ],
      "copy": {
        "name": "analyticsCopyLoop",
        "count": "[length(parameters('analyticsRuleFiles'))]",
        "mode": "Serial",
        "batchSize": 1
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), concat('AnalyticsRules/', parameters('analyticsRuleFiles')[copyIndex()]))]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('workspaceName')]" }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "[format('AutomationRule-{0}', json(concat('\"', parameters('automationRuleFiles')[copyIndex()], '\"')))]",
      "dependsOn": [
        "analyticsCopyLoop"
      ],
      "copy": {
        "name": "automationCopyLoop",
        "count": "[length(parameters('automationRuleFiles'))]",
        "mode": "Serial",
        "batchSize": 1
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), concat('AutomationRules/', parameters('automationRuleFiles')[copyIndex()]))]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('workspaceName')]" }
        }
      }
    },
    {
      "type": "Microsoft.OperationsManagement/solutions",
      "apiVersion": "2015-11-01-preview",
      "name": "[concat('SecurityInsights(', parameters('workspaceName'), ')')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "automationCopyLoop"
      ],
      "plan": {
        "name": "[concat('SecurityInsights(', parameters('workspaceName'), ')')]",
        "product": "OMSGallery/SecurityInsights",
        "publisher": "Microsoft",
        "promotionCode": ""
      },
      "properties": {
        "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
      }
    },
    {
      "type": "Microsoft.SecurityInsights/onboardingStates",
      "apiVersion": "2023-02-01",
      "name": "[concat(parameters('workspaceName'), '/default')]",
      "dependsOn": [
        "[concat('Microsoft.OperationsManagement/solutions/SecurityInsights(', parameters('workspaceName'), ')')]"
      ],
      "properties": {}
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentPackages",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/Azuresentinel-microsoft-sentinel-solutions-windowssecurityevents')]",
      "dependsOn": [
        "[concat('Microsoft.SecurityInsights/onboardingStates/', parameters('workspaceName'), '/default')]"
      ],
      "properties": {
        "contentId": "microsoft-sentinel-solutions-windowssecurityevents",
        "version": "3.0.1",
        "displayName": "Windows Security Events",
        "contentKind": "Solution"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/incidents",
      "apiVersion": "2023-12-01-preview",
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb99')]",
      "dependsOn": [
        "[concat('Microsoft.OperationalInsights/workspaces/providers/contentPackages/', parameters('workspaceName'), '/Microsoft.SecurityInsights/Azuresentinel-microsoft-sentinel-solutions-windowssecurityevents')]"
      ],
      "properties": {
        "title": "[SIMULATION ALERT] Critical PowerShell Execution Event",
        "severity": "High",
        "status": "New",
        "description": "This incident was automatically generated by the GitHub deployment pipeline to verify the end-to-end functionality of your automated rules, API connections, and response playbooks."
      }
    }
  ]
}
