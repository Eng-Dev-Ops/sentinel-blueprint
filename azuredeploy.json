{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": { "type": "string" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "_artifactsLocation": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/<YOUR_GITHUB_USER>/<YOUR_REPO_NAME>/main/"
    },
    "analyticsRuleFiles": {
      "type": "array",
      "defaultValue": [
        "brute_force_detection.json",
        "powershell_detection.json",
        "scheduled_task_hide.json"
      ]
    },
    "playbookName": {
      "type": "string",
      "defaultValue": "Sentinel-M1-Teams-Notification-Playbook"
    }
  },
  "variables": {
    // Native GUID for 'Microsoft Sentinel Playbook Responder' role
    "playbookResponderRoleDefinitionId": "f05b4121-b193-4c12-8684-edf0307e8cc1"
  },
  "resources": [
    // 1 & 2. Deploy Playbook Infrastructure
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "PlaybookDeployment",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), 'Playbooks/teams_notification.json')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": { "location": { "value": "[parameters('location')]" } }
      }
    },

    // 2.5 Force Sentinel Activation First
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "SentinelOnboardingDeployment",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), 'AnalyticsRules/sentinel_onboarding.json')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('workspaceName')]" }
        }
      }
    },

    // 3. Run Analytics Rules Loop (WAITS FOR ONBOARDING)
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "[format('RuleDeployment-{0}', json(concat('\"', parameters('analyticsRuleFiles')[copyIndex()], '\"')))]",
      "dependsOn": [
        "SentinelOnboardingDeployment"
      ],
      "copy": {
        "name": "rulesCopyLoop",
        "count": "[length(parameters('analyticsRuleFiles'))]"
      },
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(parameters('_artifactsLocation'), concat('AnalyticsRules/', parameters('analyticsRuleFiles')[copyIndex()]))]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('workspaceName')]" }
        }
      }
    },

    // 3.5 AUTOMATED SECURITY CLEARANCE: Grant Sentinel access to the Playbook
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, 'SentinelPlaybookResponder')]",
      "dependsOn": [
        "PlaybookDeployment"
      ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('playbookResponderRoleDefinitionId'))]",
        "principalId": "307907f7-4bb6-4f16-a67d-b9fb26158293", // Your regional Sentinel App Service Principal ID
        "principalType": "ServicePrincipal"
      }
    },

    // 4. Fully Automated Cross-Client Automation Rule
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspaceName'), 'Microsoft.SecurityInsights'),'/AutomationRules/7971fc96-9918-497e-ab15-3cf9b96b745e')]",
      "name": "[concat(parameters('workspaceName'),'/Microsoft.SecurityInsights/7971fc96-9918-497e-ab15-3cf9b96b745e')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/AutomationRules",
      "apiVersion": "2023-12-01-preview",
      "dependsOn": [
        "PlaybookDeployment",
        "rulesCopyLoop"
      ],
      "properties": {
        "displayName": "Client-A-Auto-Triage-and-Notify",
        "order": 1,
        "triggeringLogic": {
          "isEnabled": true,
          "triggersOn": "Incidents",
          "triggersWhen": "Created",
          "conditions": []
        },
        "actions": [
          {
            "order": 1,
            "actionType": "RunPlaybook",
            "actionConfiguration": {
              "logicAppResourceId": "[resourceId('Microsoft.Logic/workflows', parameters('playbookName'))]",
              "tenantId": "[subscription().tenantId]"
            }
          }
        ]
      }
    }
  ]
}
